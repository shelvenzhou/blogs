---
import PostMeta from '~/components/PostMeta.astro'
import type { Post } from '~/types'

interface Props {
  post: Post
  showPageViews?: boolean
}

const { post, showPageViews = false } = Astro.props
---

<article class="prose">
  <PostMeta post={post} showPageViews={showPageViews} />
  <slot />
</article>
